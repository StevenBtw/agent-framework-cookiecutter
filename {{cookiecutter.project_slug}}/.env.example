# Azure Key Vault (optional - if set, secrets are loaded from Key Vault)
KEY_VAULT_URL=

# Azure OpenAI / Model Provider
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o

{% if cookiecutter.model_provider == "pydantic_ai_custom" -%}
# Custom Model Provider (pydantic-ai)
CUSTOM_MODEL_API_KEY=
CUSTOM_MODEL_BASE_URL=
CUSTOM_MODEL_NAME=
{%- endif %}

{% if cookiecutter.memory_provider == "azure-foundry" -%}
# Azure AI Foundry Memory
FOUNDRY_PROJECT_ENDPOINT=https://your-ai-services.services.ai.azure.com/api/projects/your-project
MEMORY_STORE_NAME={{ cookiecutter.project_slug }}-memory
{%- elif cookiecutter.memory_provider == "grafeo-memory" -%}
# Grafeo Memory (one .db file per user, stored under this directory)
GRAFEO_MEMORY_DB_DIR=./memory
GRAFEO_MEMORY_MODEL=openai:gpt-4o-mini
{%- elif cookiecutter.memory_provider == "mem0" -%}
# mem0 Memory
MEM0_API_KEY=
{%- endif %}

# Inbound auth (user identity for memory isolation)
# Set AUTH_ENABLED=true to require JWT tokens on API requests.
# Anonymous requests are still allowed but get transient memory.
AUTH_ENABLED=false
# Entra ID example:
#   AUTH_JWKS_URL=https://login.microsoftonline.com/{tenant-id}/discovery/v2.0/keys
#   AUTH_AUDIENCE=api://{client-id}
#   AUTH_ISSUER=https://login.microsoftonline.com/{tenant-id}/v2.0
# Custom OIDC example:
#   AUTH_JWKS_URL=https://your-idp.example.com/.well-known/jwks.json
#   AUTH_AUDIENCE=your-api-audience
#   AUTH_ISSUER=https://your-idp.example.com/
AUTH_JWKS_URL=
AUTH_AUDIENCE=
AUTH_ISSUER=

# Human-in-the-loop
HITL_APPROVAL_TIMEOUT=300.0
HITL_TOOLS_REQUIRING_APPROVAL=send_quote_for_approval,update_preferences,create_entity

# Async API Service (fire-and-forget — results arrive via POST /webhooks/async-result)
ASYNC_API_BASE_URL=http://localhost:8080
ASYNC_API_TIMEOUT=30.0
{% if cookiecutter.auth_method == "bearer_token" -%}
ASYNC_API_API_KEY=
{%- endif %}

# Data Service (synchronous CRUD)
DATA_SERVICE_BASE_URL=http://localhost:8081
DATA_SERVICE_TIMEOUT=30.0
{% if cookiecutter.auth_method == "bearer_token" -%}
DATA_SERVICE_API_KEY=
{%- endif %}

# Logic Service (synchronous computation)
LOGIC_SERVICE_BASE_URL=http://localhost:8082
LOGIC_SERVICE_TIMEOUT=30.0
{% if cookiecutter.auth_method == "bearer_token" -%}
LOGIC_SERVICE_API_KEY=
{%- endif %}
